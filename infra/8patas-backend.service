[Unit]
Description=8Patas FastAPI Backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/8patas/backend
Environment="PATH=/var/www/8patas/backend/.venv/bin"
EnvironmentFile=/var/www/8patas/backend/.env
ExecStart=/var/www/8patas/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5

# Segurança: limita acesso do processo ao sistema
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
