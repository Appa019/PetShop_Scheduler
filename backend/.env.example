# Chave secreta para JWT — gere uma forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# OpenAI API Key (para análise de fotos de pets)
OPENAI_API_KEY=

# SMTP — Gmail: use uma "Senha de App" (não sua senha normal)
# Ative em: Conta Google > Segurança > Verificação em 2 etapas > Senhas de app
SMTP_USER=seu@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Personalizar host SMTP se não for Gmail (opcional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# CORS — origens permitidas (separadas por vírgula)
# Desenvolvimento: http://localhost:5173
# Produção: https://seu-dominio.com
ALLOWED_ORIGINS=http://localhost:5173
