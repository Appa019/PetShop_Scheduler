{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/((?!app/)(?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
